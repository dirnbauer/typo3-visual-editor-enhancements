<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en">
  <file id="visual_editor_setup" original="EXT:visual_editor_enhancements/Resources/Private/Language/locallang_setup.xlf">
    <unit id="tab">
      <segment>
        <source>Visual editor</source>
      </segment>
    </unit>
    <unit id="showLibrary">
      <segment>
        <source>Show the "Add content" button</source>
      </segment>
    </unit>
    <unit id="showLibrary.description">
      <segment>
        <source>Shows the floating button that opens the element library while editing a page in the visual editor.</source>
      </segment>
    </unit>
    <unit id="showContextButtons">
      <segment>
        <source>Show floating edit buttons</source>
      </segment>
    </unit>
    <unit id="showContextButtons.description">
      <segment>
        <source>Shows context-sensitive floating buttons while hovering or focusing content in the visual editor: link edit buttons and the per-output field settings buttons.</source>
      </segment>
    </unit>
    <unit id="fieldChooserMode">
      <segment>
        <source>Field settings panel</source>
      </segment>
    </unit>
    <unit id="fieldChooserMode.description">
      <segment>
        <source>How the field settings panel presents the fields of an element: disabled, one list with headings, or tabs like the backend form.</source>
      </segment>
    </unit>
    <unit id="fieldChooserMode.disabled">
      <segment>
        <source>Disabled</source>
      </segment>
    </unit>
    <unit id="fieldChooserMode.sections">
      <segment>
        <source>One list with headings</source>
      </segment>
    </unit>
    <unit id="fieldChooserMode.tabs">
      <segment>
        <source>Tabs like the backend form</source>
      </segment>
    </unit>
    <unit id="panelColumns">
      <segment>
        <source>Element library size</source>
      </segment>
    </unit>
    <unit id="panelColumns.description">
      <segment>
        <source>Small shows one full-width preview column; wide shows three columns.</source>
      </segment>
    </unit>
    <unit id="panelColumns.small">
      <segment>
        <source>Small (1 column)</source>
      </segment>
    </unit>
    <unit id="panelColumns.wide">
      <segment>
        <source>Wide (3 columns)</source>
      </segment>
    </unit>
  </file>
</xliff>
