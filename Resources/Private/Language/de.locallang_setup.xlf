<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0" srcLang="en" trgLang="de">
  <file id="visual_editor_setup" original="EXT:visual_editor_enhancements/Resources/Private/Language/locallang_setup.xlf">
    <unit id="tab">
      <segment state="final">
        <source>Visual editor</source>
        <target>Visueller Editor</target>
      </segment>
    </unit>
    <unit id="showLibrary">
      <segment state="final">
        <source>Show the "Add content" button</source>
        <target>Schaltfläche „Inhalt hinzufügen“ anzeigen</target>
      </segment>
    </unit>
    <unit id="showLibrary.description">
      <segment state="final">
        <source>Shows the floating button that opens the element library while editing a page in the visual editor.</source>
        <target>Zeigt die schwebende Schaltfläche, die im visuellen Editor die Element-Bibliothek öffnet.</target>
      </segment>
    </unit>
    <unit id="showContextButtons">
      <segment state="final">
        <source>Show floating edit buttons</source>
        <target>Schwebende Bearbeitungsschaltflächen anzeigen</target>
      </segment>
    </unit>
    <unit id="showContextButtons.description">
      <segment state="final">
        <source>Shows context-sensitive floating buttons while hovering or focusing content in the visual editor: link edit buttons and the element settings chip.</source>
        <target>Zeigt kontextabhängige schwebende Schaltflächen beim Überfahren oder Fokussieren von Inhalten im visuellen Editor: Link-Bearbeitung und den Element-Einstellungen-Chip.</target>
      </segment>
    </unit>
    <unit id="fieldChooserMode">
      <segment state="final">
        <source>Field settings panel</source>
        <target>Feld-Einstellungen-Panel</target>
      </segment>
    </unit>
    <unit id="fieldChooserMode.description">
      <segment state="final">
        <source>How the field settings panel presents the fields of an element: disabled, one list with headings, or tabs like the backend form.</source>
        <target>Wie das Feld-Einstellungen-Panel die Felder eines Elements darstellt: deaktiviert, eine Liste mit Überschriften oder Reiter wie im Backend-Formular.</target>
      </segment>
    </unit>
    <unit id="fieldChooserMode.disabled">
      <segment state="final">
        <source>Disabled</source>
        <target>Deaktiviert</target>
      </segment>
    </unit>
    <unit id="fieldChooserMode.sections">
      <segment state="final">
        <source>One list with headings</source>
        <target>Eine Liste mit Überschriften</target>
      </segment>
    </unit>
    <unit id="fieldChooserMode.tabs">
      <segment state="final">
        <source>Tabs like the backend form</source>
        <target>Reiter wie im Backend-Formular</target>
      </segment>
    </unit>
    <unit id="panelColumns">
      <segment state="final">
        <source>Element library size</source>
        <target>Größe der Element-Bibliothek</target>
      </segment>
    </unit>
    <unit id="panelColumns.description">
      <segment state="final">
        <source>Small shows one full-width preview column; wide shows three columns.</source>
        <target>Schmal zeigt eine Vorschauspalte über die volle Breite; breit zeigt drei Spalten.</target>
      </segment>
    </unit>
    <unit id="panelColumns.small">
      <segment state="final">
        <source>Small (1 column)</source>
        <target>Schmal (1 Spalte)</target>
      </segment>
    </unit>
    <unit id="panelColumns.wide">
      <segment state="final">
        <source>Wide (3 columns)</source>
        <target>Breit (3 Spalten)</target>
      </segment>
    </unit>
  </file>
</xliff>
